# Optional API base URL. Leave empty for same-origin (recommended in production).
VITE_API_URL=
VITE_MAIL_FROM=you@example.com
VITE_MAILBOX_USER=you@example.com

# Legacy CRA names still work during migration:
# REACT_APP_API_URL=
# REACT_APP_MAIL_FROM=you@example.com
# REACT_APP_MAILBOX_USER=you@example.com

# Local dev with Vite proxy (API on :8000, UI on :3000):
# VITE_API_URL=http://localhost:8000

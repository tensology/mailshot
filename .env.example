# Application
PORT=8000
APP_MODE=development
NODE_ENV=development

# Login (or use auth.config.json — see auth.config.example.json)
AUTH_USERNAME=you@example.com
AUTH_PASSWORD=your_password
AUTH_SESSION_TTL_MS=604800000

# Postgres (target mailbox store)
DATABASE_URL=postgres://mailshot:change_me@127.0.0.1:5432/mailshot
PGSSL=false

# Legacy MongoDB (temporary during migration)
DB_USERNAME=user
DB_PASSWORD=change_me
MONGODB_URI=mongodb://user:change_me@localhost:27017/mailshot?authSource=admin

# IMAP (incoming mail sync)
MAIL_IMAP_HOST=imap.example.com
MAIL_IMAP_PORT=993
MAILBOX_USER=you@example.com
MAILBOX_PASSWORD=your_mailbox_password

# SMTP (outgoing mail)
MAIL_SMTP_HOST=smtp.example.com
MAIL_SMTP_PORT=465
MAIL_SMTP_SECURE=true
MAIL_SMTP_REJECT_UNAUTHORIZED=false
MAIL_FROM=you@example.com
MAIL_NAME=Your Name

# Sync
MAILBOX_SYNC_ENABLED=true
MAILBOX_POLL_INTERVAL_MS=30000
